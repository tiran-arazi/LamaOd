# Ollama (OpenAI-compatible API). On Windows server, use host IP if Ollama is remote.
# Include /v1 (OpenAI-compatible surface). Wrong: http://127.0.0.1:11434 alone → 404 from the client.
OLLAMA_BASE_URL=http://127.0.0.1:11434/v1
# Match `ollama list` (e.g. llama3.2:3b, lfm2)
OLLAMA_MODEL_SPEC=ollama:llama3.2:3b

# Public sample server (replace with your ArcGIS REST root on a closed network).
# Example internal: http://your-gis-server/arcgis/rest/services
ARCGIS_CATALOG_URL=https://sampleserver6.arcgisonline.com/arcgis/rest/services

# Crawl ArcGIS catalog once when the API starts. Set false to rely on scripts/reindex_arcgis_rest_catalog.py or POST /api/catalog/reindex only.
CATALOG_INDEX_ON_STARTUP=true
# Optional: if set, POST /api/catalog/reindex requires header X-Catalog-Reindex-Token: <same value>
# CATALOG_REINDEX_TOKEN=

# Limit services per crawl (large public catalogs are slow).
CATALOG_MAX_SERVICES=25
# Field metadata is fetched for the first N layers per service only.
CATALOG_MAX_LAYERS_FIELD_DETAIL=4

# Dev: comma-separated origins for CORS when UI is not served by FastAPI.
CORS_ORIGINS=http://127.0.0.1:5173,http://localhost:5173
