# Copy to ".env" and adjust. Loaded by scripts/run-pilot.* (not auto-loaded by pip install).

# Local Ollama API (Windows: same host if Ollama is on the same server)
OLLAMA_BASE_URL=http://127.0.0.1:11434

# Store SQLite + uploads inside this repo folder (good for dev; use a fixed path on Server 2019)
DATA_DIR=

# Air-gap / offline-friendly defaults (HF cache must be populated first if you use RAG/embeddings)
OFFLINE_MODE=true
ENABLE_VERSION_UPDATE_CHECK=false

# Mermaid + Vega/Vega-Lite charts in chat need no extra pip packages (bundled in the open-webui wheel).
# USB / closed-network file checklist: docs/CLOSED-NETWORK-USB.md

# Dev pilot: skip login. For production, set true and configure WEBUI_SECRET_KEY.
WEBUI_AUTH=false

# Optional: set explicitly in prod
# WEBUI_SECRET_KEY=change-me-long-random
